<Window x:Class="wpfAssessmentTracker4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:wpfAssessmentTracker4"
        mc:Ignorable="d"
            Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Filters -->
            <RowDefinition Height="*"/>
            <!-- Current Assessments -->
            <RowDefinition Height="*"/>
            <!-- Completed Assessments -->
            <RowDefinition Height="Auto"/>
            <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- Filter Panel -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Filter Unit:" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="TxtFilterUnit" Width="100" TextChanged="FilterChanged" Margin="5"/>

            <TextBlock Text="Type:" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="TxtFilterType" Width="100" TextChanged="FilterChanged" Margin="5"/>

            <TextBlock Text="Name:" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="TxtFilterName" Width="100" TextChanged="FilterChanged" Margin="5"/>

            <Button Content="Clear Filters" Click="BtnClearFilters_Click" Padding="10,2" Margin="10,0,0,0"/>
        </StackPanel>

        <!-- Incomeplete Assessments Grid -->
        <GroupBox Header="Incomplete Assessments (Editable)" Grid.Row="1" Margin="0,0,0,10">
            <DataGrid x:Name="Incomplete_Assessments" AutoGenerateColumns="False" CanUserAddRows="True" RowEditEnding="IncompleteAssessments_Edit">
                <DataGrid.Columns>
                    <!-- Due Date Column -->
                    <DataGridTemplateColumn Header="Due Date" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DueDate, StringFormat=d, TargetNullValue=''}" 
                       VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding DueDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridComboBoxColumn Header="Grade" SelectedItemBinding="{Binding Grade}" Width="100">
                        <DataGridComboBoxColumn.ItemsSource>
                            <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                <sys:String>NYM</sys:String>
                                <sys:String>NYS</sys:String>
                                <sys:String>S</sys:String>
                            </x:Array>
                        </DataGridComboBoxColumn.ItemsSource>
                    </DataGridComboBoxColumn>
                   
                    <!-- Delete Button Column -->
                    <DataGridTemplateColumn Header="Delete" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content ="Delete" Command="Delete" Margin="2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Completed Assessments Grid -->
        <GroupBox Header="Completed Assessments" Grid.Row="2" Margin="0,0,0,10">
            <DataGrid x:Name="Completed_Assessments" AutoGenerateColumns="False" CanUserDeleteRows="True">
                <DataGrid.Columns>
                    <!-- Due Date Column -->
                    <DataGridTextColumn Header="Due Date" Binding="{Binding DueDate, StringFormat=d, TargetNullValue=''}" Width="120"/>
                    
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Grade" Binding="{Binding Grade}" Width="80"/>
                    <DataGridTextColumn Header="Date Completed" Binding="{Binding DateCompleted, StringFormat={}{0:yyyy-MM-dd}}" Width="*"/>
                   
                    <!-- Delete Button Column -->
                    <DataGridTemplateColumn Header="Delete" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Delete" Command="{x:Static DataGrid.DeleteCommand}" Margin="5,2" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Manual File IO Actions -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="3">
            <Button Content="Load From File" Click="BtnLoad_Click" Width="120" Height="30" Margin="5"/>
            <Button Content="Save To File" Click="BtnSave_Click" Width="120" Height="30" Margin="5"/>
        </StackPanel>

    </Grid>
</Window>
